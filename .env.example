# --- Backend & Environment ---
NEXT_PUBLIC_ENV_URL=http://localhost:8000
PORT=8000

# --- Training (WandB) ---
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=prism-rl
WANDB_ENTITY=your_entity_name

# --- LLM Graders (Optional/Future) ---
# Used if switching from heuristic graders to model-based graders
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# --- RL Training Config ---
MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
N_EPISODES=200
BATCH_SIZE=8
LEARNING_RATE=1e-5
